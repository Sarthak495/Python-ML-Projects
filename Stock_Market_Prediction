        "import numpy as np\n",
        "import pandas as pd # Required for pd.isna()\n",
        "\n",
        "# Ensure X_train_scaled and y_train are clean before fitting\n",
        "# Check for NaNs in X_train_scaled\n",
        "nan_mask_X = np.isnan(X_train_scaled).any(axis=1)\n",
        "\n",
        "# Check for NaNs in y_train (though unlikely for binary target)\n",
        "nan_mask_y = pd.isna(y_train)\n",
        "\n",
        "# Combine masks to find rows with NaNs in either X or y\n",
        "combined_nan_mask = nan_mask_X | nan_mask_y\n",
        "\n",
        "if np.any(combined_nan_mask):\n",
        "    num_nans = np.sum(combined_nan_mask)\n",
        "    print(f\"NaN values detected in training data (X_train_scaled or y_train). Dropping {num_nans} rows.\")\n",
        "    X_train_scaled_cleaned = X_train_scaled[~combined_nan_mask]\n",
        "    y_train_cleaned = y_train[~combined_nan_mask]\n",
        "else:\n",
        "    X_train_scaled_cleaned = X_train_scaled\n",
        "    y_train_cleaned = y_train\n",
        "\n",
        "model = LogisticRegression(random_state=42)\n",
        "model.fit(X_train_scaled_cleaned, y_train_cleaned)\n",
        "\n",
        "print(\"Logistic Regression model trained successfully.\")"
